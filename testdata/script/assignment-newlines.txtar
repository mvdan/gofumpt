exec gofumpt -w foo.go
cmp foo.go foo.go.golden

exec gofumpt -d foo.go.golden
! stdout .

-- foo.go --
package p

func f() {
    foo :=


        "bar"

    foo :=
        "bar"

	_, _ =
		0,
		1

	_, _ = 0,
		1

    _ =
        `
            foo
        `

	_ = /* inline */
		"foo"

	_ = // inline
		"foo"

	long :=
		"foo " +
			"bar " +
			"baz"
	_ = long

	a, b, c :=
		"foo",
		"bar",
		"qux"
	_, _, _ = a, b, c
}

-- foo.go.golden --
package p

func f() {
	foo := "bar"

	foo := "bar"

	_, _ =
		0,
		1

	_, _ = 0,
		1

	_ = `
            foo
        `

	_ = /* inline */ "foo"

	_ = // inline
	"foo"

	long :=
		"foo " +
			"bar " +
			"baz"
	_ = long

	a, b, c :=
		"foo",
		"bar",
		"qux"
	_, _, _ = a, b, c
}
